---
import "../styles/global.css";
const { title = "Elliot Buckland-Weir" } = Astro.props;
---
<html lang="en" class="bg-gray-950 text-gray-200 font-sans antialiased">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <title>{title}</title>

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content="Junior Security Analyst — security research, blue team notes, and tools." />
    <meta property="og:image" content="https://elliotweir.co.uk/me.jpg" />
    <meta property="og:url" content="https://elliotweir.co.uk" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Elliot Buckland-Weir" />

    <!-- Twitter/X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content="Junior Security Analyst — security research, blue team notes, and tools." />
    <meta name="twitter:image" content="https://elliotweir.co.uk/me.jpg" />
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- HEADER -->
    <header class="py-6 border-b border-gray-800">
      <nav class="max-w-5xl mx-auto px-6 flex justify-between items-center">
        <a href="/" class="flex items-center gap-3 hover:opacity-80 transition">
          <img
            src="/logo.png"
            alt="Elliot Buckland-Weir logo"
            class="h-10 w-auto"
          />
          <span class="text-xl font-bold">Elliot Buckland-Weir</span>
        </a>
        <div class="flex gap-8 text-lg">
          <a href="/research" class="hover:text-blue-400 transition">Research</a>
          <a href="/tools" class="hover:text-blue-400 transition">Tools</a>
          <a href="/cv" class="hover:text-blue-400 transition">CV</a>
        </div>
      </nav>
    </header>
    <main class="flex-1">
      <slot />
    </main>
    <!-- FOOTER -->
    <footer class="text-center py-10 text-gray-500 text-sm border-t border-gray-800">
      <div class="flex justify-center gap-6 mb-4">
        <a href="https://www.linkedin.com/in/elliot-buckland-weir/" target="_blank" rel="noopener" class="hover:text-blue-400 transition">LinkedIn</a>
        <a href="mailto:elliot@elliotweir.co.uk" class="hover:text-blue-400 transition">Email</a>
        <a href="https://github.com/0xW0lf" target="_blank" rel="noopener" class="hover:text-blue-400 transition">GitHub</a>
        <a href="https://tryhackme.com/p/0xW0lf" target="_blank" rel="noopener" class="hover:text-blue-400 transition">TryHackMe</a>
      </div>
      © {new Date().getFullYear()} Elliot Buckland-Weir
    </footer>
  </body>
</html>