---
import "../styles/global.css";
const { title = "Elliot Buckland-Weir" } = Astro.props;
---
<html lang="en" class="bg-gray-950 text-gray-200 font-sans antialiased">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon-v2.ico" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- HEADER -->
    <header class="py-6 border-b border-gray-800">
      <nav class="max-w-5xl mx-auto px-6 flex justify-between items-center">
        <a href="/" class="flex items-center gap-3 hover:opacity-80 transition">
          <img
            src="/logo.png"
            alt="Elliot Buckland-Weir logo"
            class="h-8 w-auto"
          />
          <span class="text-xl font-bold">Elliot Buckland-Weir</span>
        </a>
        <div class="flex gap-8 text-lg">
          <a href="/research" class="hover:text-blue-400 transition">Research</a>
          <a href="/tools" class="hover:text-blue-400 transition">Tools</a>
          <a href="/cv" class="hover:text-blue-400 transition">CV</a>
        </div>
      </nav>
    </header>
    <main class="flex-1">
      <slot />
    </main>
    <!-- FOOTER -->
    <footer class="text-center py-10 text-gray-500 text-sm border-t border-gray-800">
      © {new Date().getFullYear()} Elliot Buckland-Weir
    </footer>
  </body>
</html>