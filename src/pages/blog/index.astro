---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
const posts = await getCollection("blog");

const allTags = [...new Set(posts.flatMap(post => post.data.tags ?? []))].sort();
const tagCounts = Object.fromEntries(
  allTags.map(tag => [tag, posts.filter(p => (p.data.tags ?? []).includes(tag)).length])
);
---

<BaseLayout title="Blog">
  <section class="max-w-6xl mx-auto px-6 py-20">
    <h1 class="text-4xl font-bold mb-10">Blog</h1>

    <div class="flex gap-10">

      <!-- SIDEBAR -->
      <aside class="w-56 shrink-0">
        <div class="sticky top-8">
          <!-- Search -->
          <input
            id="search"
            type="text"
            placeholder="Search posts..."
            class="w-full px-3 py-2 mb-6 bg-gray-900 border border-gray-700 rounded-lg text-sm text-gray-200 placeholder-gray-500 focus:outline-none focus:border-blue-500"
          />

          <!-- Tags -->
          <h2 class="text-xs uppercase tracking-widest text-gray-500 mb-3">Filter by tag</h2>
          <div class="flex flex-col gap-2" id="tag-list">
            <button
              data-tag="all"
              class="tag-btn text-left px-3 py-1.5 rounded-lg text-sm bg-blue-600 text-white transition"
            >
              All posts ({posts.length})
            </button>
            {allTags.map(tag => (
              <button
                data-tag={tag}
                class="tag-btn text-left px-3 py-1.5 rounded-lg text-sm bg-gray-900 border border-gray-800 text-gray-300 hover:border-blue-500 transition"
              >
                {tag} ({tagCounts[tag]})
              </button>
            ))}
          </div>

          <!-- Clear -->
          <button
            id="clear-btn"
            class="mt-4 text-xs text-gray-500 hover:text-blue-400 transition hidden"
          >
            Clear filter
          </button>
        </div>
      </aside>

      <!-- POSTS -->
      <div class="flex-1">
        {posts.length === 0 && (
          <p class="text-gray-400">No blog posts yet. Check back soon.</p>
        )}
        <div class="flex flex-col gap-6" id="post-list">
          {posts.map(post => (
            <a
              href={"/blog/" + post.id}
              data-tags={(post.data.tags ?? []).join(",")}
              class="post-card block p-6 bg-gray-900 border border-gray-800 rounded-lg hover:bg-gray-800 transition"
            >
              <div class="flex flex-wrap gap-2 mb-3">
                {(post.data.tags ?? []).map(tag => (
                  <span class="text-xs px-2 py-0.5 bg-gray-800 border border-gray-700 rounded-full text-blue-400">
                    {tag}
                  </span>
                ))}
              </div>
              <h2 class="text-2xl font-semibold mb-2">{post.data.title}</h2>
              <p class="text-gray-400">{post.data.description}</p>
            </a>
          ))}
        </div>
        <p id="no-results" class="text-gray-500 hidden">No posts match your search.</p>
      </div>

    </div>
  </section>
</BaseLayout>

<script>
  const searchInput = document.getElementById("search") as HTMLInputElement;
  const tagBtns = document.querySelectorAll(".tag-btn") as NodeListOf<HTMLButtonElement>;
  const postCards = document.querySelectorAll(".post-card") as NodeListOf<HTMLElement>;
  const clearBtn = document.getElementById("clear-btn") as HTMLButtonElement;
  const noResults = document.getElementById("no-results") as HTMLElement;

  let activeTag = "all";

  function filterPosts() {
    const query = searchInput.value.toLowerCase();
    let visible = 0;

    postCards.forEach(card => {
      const tags = card.dataset.tags ? card.dataset.tags.split(",") : [];
      const title = card.querySelector("h2")?.textContent?.toLowerCase() ?? "";
      const matchesTag = activeTag === "all" || tags.includes(activeTag);
      const matchesSearch = title.includes(query);

      if (matchesTag && matchesSearch) {
        card.style.display = "block";
        visible++;
      } else {
        card.style.display = "none";
      }
    });

    noResults.classList.toggle("hidden", visible > 0);
    clearBtn.classList.toggle("hidden", activeTag === "all" && query === "");
  }

  tagBtns.forEach(btn => {
    btn.addEventListener("click", () => {
      activeTag = btn.dataset.tag ?? "all";

      tagBtns.forEach(b => {
        b.className = "tag-btn text-left px-3 py-1.5 rounded-lg text-sm bg-gray-900 border border-gray-800 text-gray-300 hover:border-blue-500 transition";
      });
      btn.className = "tag-btn text-left px-3 py-1.5 rounded-lg text-sm bg-blue-600 text-white transition";

      filterPosts();
    });
  });

  searchInput.addEventListener("input", filterPosts);

  clearBtn.addEventListener("click", () => {
    activeTag = "all";
    searchInput.value = "";
    tagBtns.forEach((b, i) => {
      b.className = i === 0
        ? "tag-btn text-left px-3 py-1.5 rounded-lg text-sm bg-blue-600 text-white transition"
        : "tag-btn text-left px-3 py-1.5 rounded-lg text-sm bg-gray-900 border border-gray-800 text-gray-300 hover:border-blue-500 transition";
    });
    filterPosts();
  });
</script>