---
import BaseLayout from "../layouts/BaseLayout.astro";
const title = "Write-ups • Elliot Buckland-Weir";

const writeups = [
  {
    title: "Bypassing Weak MFA with Token Replay",
    description: "A walkthrough of exploiting poorly implemented MFA flows using intercepted session tokens.",
    link: "/writeups/mfa-token-replay"
  },
  {
    title: "Privilege Escalation via Misconfigured Intune Policies",
    description: "How a mis-scoped device policy allowed unintended admin access.",
    link: "/writeups/intune-priv-esc"
  },
  {
    title: "SharePoint External Sharing Misconfiguration",
    description: "A real-world case study of data exposure caused by incorrect B2B settings.",
    link: "/writeups/sharepoint-external"
  }
];
---

<BaseLayout {title}>
  <section class="text-center py-20 px-6">
    <h1 class="text-5xl font-bold mb-4">Write-ups</h1>
    <p class="text-xl text-gray-400 max-w-2xl mx-auto">
      Security incidents, research notes, and technical breakdowns from my work and experiments.
    </p>
  </section>

  <section class="max-w-4xl mx-auto px-6 space-y-6 pb-24">
    {writeups.map(w => (
      <a href={w.link} class="block p-6 bg-gray-900 rounded-xl border border-gray-800 hover:border-blue-500 hover:bg-gray-850 transition">
        <h2 class="text-2xl font-semibold mb-2">{w.title}</h2>
        <p class="text-gray-400">{w.description}</p>
      </a>
    ))}
  </section>
</BaseLayout>
