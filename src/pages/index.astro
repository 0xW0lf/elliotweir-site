---
import BaseLayout from "../layouts/BaseLayout.astro";
const name = "Elliot Buckland-Weir";
const tagline = "Junior Security Analyst | Builder | Problem Solver";
const title = name + " — Home";
---
<BaseLayout title={title}>

  <<!-- HERO -->
<section class="text-center py-28 px-6 border-b border-gray-800">
  <div class="w-full flex justify-center mb-8">
    <img
      src="/me.jpg"
      alt="Photo of Elliot Buckland-Weir"
      class="w-32 h-32 rounded-full object-cover border-4 border-gray-700 shadow-lg"
    />
  </div>

  <h1 class="text-6xl font-extrabold tracking-tight mb-4">
    {name}
  </h1>

  <p class="text-xl text-gray-400 max-w-2xl mx-auto mb-4">
    Security Analyst | Cybersecurity Researcher | Automation Builder
  </p>

  <p class="text-gray-500 max-w-3xl mx-auto mb-8 leading-relaxed">
    Exploring defensive security through hands-on research, technical
    write-ups, practical labs, and verified certifications.
  </p>

  <div class="flex flex-wrap justify-center gap-4 text-sm">
    <a
      href="/research"
      class="px-5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white rounded-lg transition"
    >
      🔬 Research
    </a>

    <a
      href="/certifications"
      class="px-5 py-2.5 bg-green-600 hover:bg-green-500 text-white rounded-lg transition"
    >
      🏅 Certifications
    </a>

    <a
      href="/cv"
      class="px-5 py-2.5 bg-gray-800 hover:bg-gray-700 text-gray-200 rounded-lg transition"
    >
      📄 View CV
    </a>
  </div>
</section>

  <!-- ABOUT -->
<section class="max-w-3xl mx-auto px-6 py-20 border-b border-gray-800">
  <h2 class="text-2xl font-semibold mb-6 text-gray-100">About Me</h2>

  <p class="text-gray-300 leading-relaxed text-lg">
    Hi, I'm Elliot, a Security Analyst based in the UK with a passion for
    defensive cybersecurity, automation, and continuous learning. I enjoy
    understanding how systems work, investigating security problems, and
    building practical solutions that improve resilience.
  </p>

  <p class="text-gray-300 leading-relaxed text-lg mt-4">
    My experience includes endpoint security, governance, Microsoft 365
    administration, phishing awareness, automation, and incident response.
    Alongside my professional work, I'm continually expanding my technical
    knowledge through hands-on labs, security research, and personal projects.
  </p>

  <p class="text-gray-300 leading-relaxed text-lg mt-4">
    This website is my technical portfolio, a place where I document research,
    share write-ups, showcase tools I've built, and track my journey as I
    continue developing my skills within cybersecurity.
  </p>
</section>

<!-- TRYHACKME -->
<section class="max-w-5xl mx-auto px-6 py-20">
  <h2 class="text-2xl font-semibold mb-8 text-gray-100">TryHackMe</h2>

  <div class="grid gap-8 md:grid-cols-2">

    <!-- TryHackMe Profile -->
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
      <h3 class="text-lg font-semibold text-white mb-2">
        TryHackMe Profile
      </h3>

      <p class="text-gray-400 text-sm mb-6">
        Follow my progress through hands-on cyber security labs,
        learning paths, and practical challenges.
      </p>

      <a
        href="https://tryhackme.com/p/0xW0lf"
        target="_blank"
        rel="noopener"
      >
        <img
          src="https://tryhackme-badges.s3.amazonaws.com/0xW0lf.png"
          alt="TryHackMe Badge for 0xW0lf"
          class="h-24 w-auto opacity-90 hover:opacity-100 transition"
        />
      </a>
    </div>

    <!-- SEC0 Certification -->
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
      <h3 class="text-lg font-semibold text-white mb-2">
        Latest Certification
      </h3>

      <p class="text-gray-400 text-sm mb-6">
        TryHackMe Certified Pre Security (SEC0)
        <br />
        <span class="text-green-400">Awarded June 2026</span>
      </p>

      <img
        src="/pre-security-sec0.png"
        alt="TryHackMe Certified Pre Security (SEC0)"
        class="h-32 w-auto rounded-lg shadow-md mb-6"
      />

      <a
        href="https://www.credly.com/badges/9634e68e-1e13-49e6-8db6-b346937df0cb/public_url"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center rounded-lg bg-green-600 px-4 py-2 text-sm font-medium text-white hover:bg-green-500 transition"
      >
        View Credential
      </a>
    </div>

  </div>
</section>

</BaseLayout>