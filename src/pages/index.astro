---
import BaseLayout from "../layouts/BaseLayout.astro";

const name = "Elliot Buckland-Weir";
const tagline = "Security Analyst | Builder | Problem Solver";
const title = `${name} — Home`;
---

<BaseLayout {title}>
  <!-- HERO -->
  <section class="text-center py-28 px-6">
    <h1 class="text-6xl font-extrabold tracking-tight mb-6">{name}</h1>
    <p class="text-2xl text-gray-400 max-w-2xl mx-auto">
      {tagline}
    </p>
  </section>

  <!-- QUICK LINKS -->
  <section class="flex justify-center gap-12 text-xl mb-24">
    <a href="/blog" class="hover:text-blue-400 transition">Blog</a>
    <a href="/tools" class="hover:text-blue-400 transition">Tools</a>
    <a href="/writeups" class="hover:text-blue-400 transition">Write-ups</a>
  </section>

  <!-- ABOUT -->
  <section class="max-w-3xl mx-auto px-6 mb-24">
    <h2 class="text-3xl font-semibold mb-4">About Me</h2>
    <p class="text-gray-300 leading-relaxed text-lg">
      I'm Elliot, a Security Analyst based in the UK. I build tools, write about security,
      and break things to understand how they work. This site is my home for projects,
      write-ups, and experiments.
    </p>
  </section>

  <!-- FEATURED -->
  <section class="max-w-3xl mx-auto px-6 mb-24">
    <h2 class="text-3xl font-semibold mb-4">Featured</h2>
    <ul class="space-y-3 text-lg">
      <li><a href="/blog" class="text-blue-400 hover:underline">Latest blog posts →</a></li>
      <li><a href="/writeups" class="text-blue-400 hover:underline">Recent write-ups →</a></li>
    </ul>
  </section>
</BaseLayout>
