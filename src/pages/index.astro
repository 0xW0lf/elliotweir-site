---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const name = "Elliot Buckland-Weir";
const title = name + " — Home";

const allPosts = await getCollection("research");
const latestPosts = allPosts
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .slice(0, 3);
---
<BaseLayout title={title}>

  <!-- HERO -->
  <section class="text-center py-28 px-6 border-b border-gray-800">
    <div class="w-full flex justify-center mb-8">
      <img
        src="/me.jpg"
        alt="Photo of Elliot Buckland-Weir"
        class="w-32 h-32 rounded-full object-cover border-4 border-gray-700 shadow-lg"
      />
    </div>
    <h1 class="text-6xl font-extrabold tracking-tight mb-4">{name}</h1>
    <p class="text-xl text-gray-400 max-w-2xl mx-auto mb-4">
      Security Analyst | Cybersecurity Researcher | Automation Builder
    </p>
    <p class="text-gray-500 max-w-3xl mx-auto mb-8 leading-relaxed">
      Exploring defensive security through hands-on research, technical write-ups, practical labs, and verified certifications.
    </p>
    <div class="flex flex-wrap justify-center gap-4 text-sm">
      <a href="/research" class="px-5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white rounded-lg transition font-medium">
        Research
      </a>
      <a href="/certifications" class="px-5 py-2.5 bg-emerald-600 hover:bg-emerald-500 text-white rounded-lg transition font-medium">
        Certifications
      </a>
      <a href="/cv" class="px-5 py-2.5 border border-white hover:bg-white hover:text-gray-900 text-white rounded-lg transition font-medium">
        View CV
      </a>
      <a href="/github.com/0xW0lf" target="_blank" rel="noopener" class="px-5 py-2.5 border border-white hover:bg-white hover:text-gray-900 text-white rounded-lg transition font-medium">
        GitHub
      </a>
    </div>
  </section>

  <!-- ABOUT -->
  <section class="max-w-3xl mx-auto px-6 py-20 border-b border-gray-800">
    <h2 class="text-2xl font-semibold mb-6 text-gray-100">About Me</h2>
    <p class="text-gray-300 leading-relaxed text-lg">
      Hi, I'm Elliot, a Security Analyst based in the UK with a passion for defensive cybersecurity, automation, and continuous learning. I enjoy understanding how systems work, investigating security problems, and building practical solutions that improve resilience.
    </p>
    <p class="text-gray-300 leading-relaxed text-lg mt-4">
      My experience includes endpoint security, governance, Microsoft 365 administration, phishing awareness, automation, and incident response. Alongside my professional work, I'm continually expanding my technical knowledge through hands-on labs, security research, and personal projects.
    </p>
    <p class="text-gray-300 leading-relaxed text-lg mt-4">
      This website is my technical portfolio, a place where I document research, share write-ups, showcase tools I've built, and track my journey as I continue developing my skills within cybersecurity.
    </p>
  </section>

  <!-- LATEST POSTS -->
  <section class="max-w-5xl mx-auto px-6 py-20 border-b border-gray-800">
    <div class="flex justify-between items-center mb-8">
      <h2 class="text-2xl font-semibold text-gray-100">Latest Research</h2>
      <a href="/research" class="text-sm text-blue-400 hover:underline">View all</a>
    </div>
    <div class="grid gap-6 md:grid-cols-3">
      {latestPosts.map(post => (
        <a
          href={"/research/" + post.id}
          class="block p-6 bg-gray-900 border border-gray-800 rounded-xl hover:bg-gray-800 transition"
        >
          <div class="flex flex-wrap gap-2 mb-3">
            {(post.data.tags ?? []).slice(0, 2).map(tag => (
              <span class="text-xs px-2 py-0.5 bg-gray-800 border border-gray-700 rounded-full text-blue-400">
                {tag}
              </span>
            ))}
          </div>
          <h3 class="text-lg font-semibold mb-2 text-gray-100">{post.data.title}</h3>
          <p class="text-gray-400 text-sm mb-4">{post.data.description}</p>
          <p class="text-xs text-gray-500">
            {new Date(post.data.pubDate).toLocaleDateString("en-GB", { day: "numeric", month: "long", year: "numeric" })}
          </p>
        </a>
      ))}
    </div>
  </section>
  <!-- TRYHACKME -->
  <section class="max-w-5xl mx-auto px-6 py-20 border-b border-gray-800">
    <h2 class="text-2xl font-semibold mb-8 text-gray-100">TryHackMe</h2>
    <div class="grid gap-8 md:grid-cols-2">

      <!-- TryHackMe Profile -->
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
        <h3 class="text-lg font-semibold text-white mb-2">TryHackMe Profile</h3>
        <p class="text-gray-400 text-sm mb-6">
          Follow my progress through hands-on cyber security labs, learning paths, and practical challenges.
        </p>
        <a href="https://tryhackme.com/p/0xW0lf" target="_blank" rel="noopener">
          <img
            src="https://tryhackme-badges.s3.amazonaws.com/0xW0lf.png"
            alt="TryHackMe Badge for 0xW0lf"
            class="h-24 w-auto opacity-90 hover:opacity-100 transition"
          />
        </a>
      </div>

      <!-- SEC0 Certification -->
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
        <h3 class="text-lg font-semibold text-white mb-2">Latest Certification</h3>
        <p class="text-gray-400 text-sm mb-6">
          TryHackMe Certified Pre Security (SEC0)
          <br />
          <span class="text-green-400">Awarded June 2026</span>
        </p>
        <img
          src="/pre-security-sec0.png"
          alt="TryHackMe Certified Pre Security (SEC0)"
          class="h-32 w-auto rounded-lg shadow-md mb-6"
        />
        <a
          href="https://www.credly.com/badges/9634e68e-1e13-49e6-8db6-b346937df0cb/public_url"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center rounded-lg bg-green-600 px-4 py-2 text-sm font-medium text-white hover:bg-green-500 transition"
        >
          View Credential
        </a>
      </div>

    </div>
  </section>

</BaseLayout>