---
import BaseLayout from "../layouts/BaseLayout.astro";
const name = "Elliot Buckland-Weir";
const tagline = "Junior Security Analyst | Builder | Problem Solver";
const title = name + " — Home";
---
<BaseLayout title={title}>

  <!-- HERO -->
  <section class="text-center py-28 px-6 border-b border-gray-800">
    <div class="w-full flex justify-center mb-8">
      <img
        src="/me.jpg"
        alt="Photo of Elliot Buckland-Weir"
        class="w-32 h-32 rounded-full object-cover border-4 border-gray-700 shadow-lg"
      />
    </div>
    <h1 class="text-6xl font-extrabold tracking-tight mb-4">{name}</h1>
    <p class="text-xl text-gray-400 max-w-2xl mx-auto mb-8">{tagline}</p>
    <div class="flex justify-center gap-6 text-sm">
      <a href="/research" class="px-4 py-2 bg-blue-600 hover:bg-blue-500 text-white rounded-lg transition">Research</a>
      <a href="/cv" class="px-4 py-2 bg-gray-800 hover:bg-gray-700 text-gray-200 rounded-lg transition">View CV</a>
    </div>
  </section>

  <!-- ABOUT -->
  <section class="max-w-3xl mx-auto px-6 py-20 border-b border-gray-800">
    <h2 class="text-2xl font-semibold mb-6 text-gray-100">About Me</h2>
    <p class="text-gray-300 leading-relaxed text-lg">
      I'm Elliot, a Security Analyst based in the UK with a background in endpoint security,
      governance, automation, and incident response. I specialise in strengthening
      organisational security through practical tooling, clear processes, and hands-on
      problem solving.
    </p>
    <p class="text-gray-300 leading-relaxed text-lg mt-4">
      My experience spans threat detection, SharePoint and Teams governance,
      Conditional Access design, phishing simulation, and executive-level reporting.
      I've built internal tools, automated workflows, and improved security posture across
      multiple environments — always with a focus on clarity, reliability, and real-world impact.
    </p>
    <p class="text-gray-300 leading-relaxed text-lg mt-4">
      This site is where I share my research, tools, and experiments — everything from
      security findings to automation scripts to the occasional deep dive into how things
      break (and how to fix them).
    </p>
  </section>

  <!-- FEATURED -->
  <section class="max-w-3xl mx-auto px-6 py-20 border-b border-gray-800">
    <h2 class="text-2xl font-semibold mb-6 text-gray-100">Featured</h2>
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      <a href="/research" class="block p-5 bg-gray-900 border border-gray-800 rounded-lg hover:bg-gray-800 transition">
        <p class="text-blue-400 font-medium mb-1">Research</p>
        <p class="text-gray-400 text-sm">Write-ups, analysis, and security findings.</p>
      </a>
      <a href="/writeups" class="block p-5 bg-gray-900 border border-gray-800 rounded-lg hover:bg-gray-800 transition">
        <p class="text-blue-400 font-medium mb-1">Write-ups</p>
        <p class="text-gray-400 text-sm">CTF solutions and lab walkthroughs.</p>
      </a>
    </div>
  </section>

  <!-- TRYHACKME -->
  <section class="max-w-3xl mx-auto px-6 py-20">
    <h2 class="text-2xl font-semibold mb-6 text-gray-100">TryHackMe</h2>
    <a href="https://tryhackme.com/p/0xW0lf" target="_blank" rel="noopener">
      <img
        src="https://tryhackme-badges.s3.amazonaws.com/0xW0lf.png"
        alt="TryHackMe Badge for 0xW0lf"
        class="h-24 w-auto opacity-90 hover:opacity-100 transition"
      />
    </a>
  </section>

</BaseLayout>