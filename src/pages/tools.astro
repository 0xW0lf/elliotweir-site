---
import BaseLayout from "../layouts/BaseLayout.astro";
const title = "Tools • Elliot Buckland-Weir";

const tools = [
  {
    name: "Hash Generator",
    description: "Generate SHA256, MD5, and other hashes instantly.",
    link: "/tools/hashgen"
  },
  {
    name: "URL Encoder / Decoder",
    description: "Encode or decode URLs for testing and debugging.",
    link: "/tools/url"
  },
  {
    name: "Base64 Utility",
    description: "Encode or decode Base64 strings quickly.",
    link: "/tools/base64"
  },
  {
    name: "IP Info Lookup",
    description: "Get geolocation and ASN information for any IP.",
    link: "/tools/ip"
  }
];
---

<BaseLayout {title}>
  <section class="text-center py-20 px-6">
    <h1 class="text-5xl font-bold mb-4">Tools</h1>
    <p class="text-xl text-gray-400 max-w-2xl mx-auto">
      A growing collection of utilities I use for security work, testing, and automation.
    </p>
  </section>

  <section class="max-w-4xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 gap-8 pb-24">
    {tools.map(tool => (
      <a href={tool.link} class="block p-6 bg-gray-900 rounded-xl border border-gray-800 hover:border-blue-500 hover:bg-gray-850 transition">
        <h2 class="text-2xl font-semibold mb-2">{tool.name}</h2>
        <p class="text-gray-400">{tool.description}</p>
      </a>
    ))}
  </section>
</BaseLayout>
